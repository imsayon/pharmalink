<%- include('partials/head') %>
<%- include('partials/flash') %>
<%- include('partials/sidebar') %>

<div class="mb-6"><h1 class="text-2xl font-bold text-slate-800">Inventory Alerts</h1><p class="text-slate-500 text-sm mt-1">Monitor expiring medicines and low stock warnings.</p></div>

<div class="space-y-8">
  <!-- Expired -->
  <div class="glass-card overflow-hidden border-t-4 border-t-red-500">
    <div class="p-4 bg-red-50/50 border-b border-red-100 flex items-center justify-between"><h2 class="font-bold text-red-800 flex items-center gap-2"><i class="fas fa-times-circle"></i> Expired Medicines</h2><span class="bg-red-100 text-red-800 text-xs font-bold px-2 py-1 rounded-full"><%= expired.length %> Items</span></div>
    <div class="p-0 overflow-x-auto"><table class="w-full text-left text-sm"><thead class="bg-white border-b border-slate-100 text-slate-500"><tr><th class="p-3">Medicine</th><th class="p-3">Batch No</th><th class="p-3">Expiry Date</th><th class="p-3">Stock</th></tr></thead><tbody>
      <% if (expired.length) { expired.forEach(med => { %><tr class="hover:bg-slate-50 border-b border-slate-50"><td class="p-3 font-bold text-slate-800"><%= med.medicine_name %></td><td class="p-3 text-slate-500"><%= med.batch_no %></td><td class="p-3 text-red-600 font-bold"><%= med.expiry_date %></td><td class="p-3 text-slate-600"><%= med.stock_quantity %></td></tr><% }); } else { %><tr><td colspan="4" class="p-6 text-center text-slate-400">No expired medicines found.</td></tr><% } %>
    </tbody></table></div>
  </div>

  <!-- Expiring Soon -->
  <div class="glass-card overflow-hidden border-t-4 border-t-yellow-400">
    <div class="p-4 bg-yellow-50/50 border-b border-yellow-100 flex items-center justify-between"><h2 class="font-bold text-yellow-800 flex items-center gap-2"><i class="fas fa-clock"></i> Expiring within 30 Days</h2><span class="bg-yellow-100 text-yellow-800 text-xs font-bold px-2 py-1 rounded-full"><%= expiring_soon.length %> Items</span></div>
    <div class="p-0 overflow-x-auto"><table class="w-full text-left text-sm"><thead class="bg-white border-b border-slate-100 text-slate-500"><tr><th class="p-3">Medicine</th><th class="p-3">Batch No</th><th class="p-3">Expiry Date</th><th class="p-3">Stock</th></tr></thead><tbody>
      <% if (expiring_soon.length) { expiring_soon.forEach(med => { %><tr class="hover:bg-slate-50 border-b border-slate-50"><td class="p-3 font-bold text-slate-800"><%= med.medicine_name %></td><td class="p-3 text-slate-500"><%= med.batch_no %></td><td class="p-3 text-yellow-600 font-bold"><%= med.expiry_date %></td><td class="p-3 text-slate-600"><%= med.stock_quantity %></td></tr><% }); } else { %><tr><td colspan="4" class="p-6 text-center text-slate-400">No medicines expiring soon.</td></tr><% } %>
    </tbody></table></div>
  </div>

  <!-- Low Stock -->
  <div class="glass-card overflow-hidden border-t-4 border-t-orange-400">
    <div class="p-4 bg-orange-50/50 border-b border-orange-100 flex items-center justify-between"><h2 class="font-bold text-orange-800 flex items-center gap-2"><i class="fas fa-exclamation-triangle"></i> Low Stock (≤ 10)</h2><span class="bg-orange-100 text-orange-800 text-xs font-bold px-2 py-1 rounded-full"><%= low_stock.length %> Items</span></div>
    <div class="p-0 overflow-x-auto"><table class="w-full text-left text-sm"><thead class="bg-white border-b border-slate-100 text-slate-500"><tr><th class="p-3">Medicine</th><th class="p-3">Category</th><th class="p-3">Price</th><th class="p-3">Stock Left</th></tr></thead><tbody>
      <% if (low_stock.length) { low_stock.forEach(med => { %><tr class="hover:bg-slate-50 border-b border-slate-50"><td class="p-3 font-bold text-slate-800"><%= med.medicine_name %></td><td class="p-3 text-slate-500"><%= med.category %></td><td class="p-3 text-slate-600">₹<%= parseFloat(med.price).toFixed(2) %></td><td class="p-3 font-bold <%= med.stock_quantity === 0 ? 'text-red-600' : 'text-orange-500' %>"><%= med.stock_quantity %></td></tr><% }); } else { %><tr><td colspan="4" class="p-6 text-center text-slate-400">Stock levels are healthy.</td></tr><% } %>
    </tbody></table></div>
  </div>
</div>

<%- include('partials/sidebar_end') %>
<%- include('partials/footer') %>
