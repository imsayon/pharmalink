<%- include('partials/head') %>
<%- include('partials/flash') %>
<%- include('partials/sidebar') %>

<div class="mb-6"><h1 class="text-2xl font-bold text-slate-800">Payment History</h1><p class="text-slate-500 text-sm mt-1">Review all transaction records and payment statuses.</p></div>

<div class="glass-card overflow-hidden">
  <div class="p-4 border-b border-slate-200 bg-slate-50 flex items-center justify-between">
    <h2 class="font-bold text-slate-700">Recent Transactions</h2>
    <select class="border border-slate-200 rounded-lg text-sm px-3 py-1.5 bg-white text-slate-700"><option value="">All Methods</option><option value="Cash">Cash</option><option value="Card">Card</option><option value="UPI">UPI</option></select>
  </div>
  <div class="overflow-x-auto">
    <table class="w-full text-left text-sm">
      <thead class="bg-white border-b border-slate-100 text-slate-500 uppercase tracking-wider text-xs"><tr><th class="p-4 font-semibold">Payment ID</th><th class="p-4 font-semibold">Bill Ref</th><th class="p-4 font-semibold">Customer</th><th class="p-4 font-semibold">Date & Time</th><th class="p-4 font-semibold">Method</th><th class="p-4 font-semibold text-right">Amount</th></tr></thead>
      <tbody class="divide-y divide-slate-100 bg-white">
        <% if (payments.length) { payments.forEach(p => {
          let mc = 'bg-blue-100 text-blue-700', ic = 'fas fa-mobile-alt';
          if (p.payment_method === 'Cash') { mc = 'bg-green-100 text-green-700'; ic = 'fas fa-money-bill-wave'; }
          else if (p.payment_method === 'Card') { mc = 'bg-purple-100 text-purple-700'; ic = 'fas fa-credit-card'; }
        %>
        <tr class="hover:bg-slate-50/50 transition-colors">
          <td class="p-4 font-medium text-slate-700">#PAY-<%= p.payment_id %></td>
          <td class="p-4"><a href="/billing/invoice/<%= p.bill_id %>" class="text-blue-600 hover:underline font-medium">#BILL-<%= p.bill_id %></a></td>
          <td class="p-4 text-slate-800"><%= p.customer_name %></td>
          <td class="p-4 text-slate-500"><%= p.payment_date %></td>
          <td class="p-4"><span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium <%= mc %>"><i class="<%= ic %>"></i> <%= p.payment_method %></span></td>
          <td class="p-4 text-right font-bold text-slate-800">₹<%= parseFloat(p.amount).toFixed(2) %></td>
        </tr>
        <% }); } else { %>
        <tr><td colspan="6" class="p-8 text-center text-slate-500"><i class="fas fa-receipt text-4xl text-slate-300 mb-3"></i><p>No payment records found.</p></td></tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<%- include('partials/sidebar_end') %>
<%- include('partials/footer') %>
