<% if (typeof messages !== 'undefined') {
  const allMsgs = [];
  if (messages.success) messages.success.forEach(m => allMsgs.push({cat: 'success', text: m}));
  if (messages.error) messages.error.forEach(m => allMsgs.push({cat: 'error', text: m}));
  if (messages.info) messages.info.forEach(m => allMsgs.push({cat: 'info', text: m}));
  if (allMsgs.length > 0) { %>
<div id="flash-container" class="fixed top-4 right-4 z-[100] flex flex-col gap-2">
  <% allMsgs.forEach(msg => { %>
    <div class="px-4 py-3 rounded-lg shadow-lg border-l-4 transition-all duration-500 ease-in-out
      <%= msg.cat === 'success' ? 'bg-white border-green-500 text-green-700' : msg.cat === 'error' ? 'bg-white border-red-500 text-red-700' : 'bg-white border-blue-500 text-blue-700' %>">
      <div class="flex items-center justify-between">
        <p class="font-medium"><%= msg.text %></p>
        <button onclick="this.parentElement.parentElement.remove()" class="ml-4 text-gray-400 hover:text-gray-600">
          <i class="fas fa-times"></i>
        </button>
      </div>
    </div>
  <% }); %>
</div>
<% } } %>
